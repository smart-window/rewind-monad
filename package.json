    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "ganache": "^7.9.2",
    "solc": "^0.8.30",
    "typescript": "^5.8.3",
    "vite": "^8.1.4"
  },
  "engines": {
    "node": ">=22"
  }
}
